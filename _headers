# Final Netlify headers for TRRB.
# Security headers are global. ICE cache headers are exact and non-overlapping.

/*
  Content-Security-Policy: upgrade-insecure-requests; block-all-mixed-content
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/topic/ice/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/assets/ice-topic.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/assets/ice-topic.css
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/data/ice-news.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/data/ice-dashboard.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/data/ice-state.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  CDN-Cache-Control: no-store
  Netlify-CDN-Cache-Control: no-store
  Pragma: no-cache
  Expires: 0

/assets/news-images/*
  Cache-Control: public, max-age=3600, must-revalidate

/assets/category-placeholders/*
  Cache-Control: public, max-age=604800

/assets/icons/*
  Cache-Control: public, max-age=604800
