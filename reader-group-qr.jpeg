
:root {
  --red: #d60000;
  --dark: #07152b;
  --muted: #64748b;
  --border: #e5e7eb;
  --bg: #f8fafc;
  --card: #ffffff;
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  background: var(--bg);
  color: var(--dark);
}
.hidden { display: none !important; }
.login-wrap {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 24px;
}
.login-card {
  width: min(460px, 100%);
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 36px;
  box-shadow: 0 20px 50px rgba(15, 23, 42, .08);
}
.brand {
  color: var(--red);
  font-size: 28px;
  font-weight: 900;
  margin-bottom: 18px;
}
h1 {
  margin: 0 0 16px;
  font-size: 36px;
}
p { color: var(--muted); }
label {
  display: block;
  margin: 18px 0 8px;
  font-weight: 800;
}
input, textarea, select {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 13px 14px;
  font: inherit;
  background: white;
}
button {
  border: 0;
  border-radius: 10px;
  padding: 12px 18px;
  font: inherit;
  font-weight: 800;
  cursor: pointer;
  background: var(--red);
  color: white;
}
.login-card button {
  width: 100%;
  margin-top: 18px;
  padding: 15px;
}
.message {
  margin-top: 14px;
  font-weight: 800;
  color: var(--red);
  white-space: pre-wrap;
}
.admin-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 260px 1fr;
}
.sidebar {
  background: #0b1220;
  color: white;
  padding: 22px;
}
.logo b {
  display: block;
  color: #fff;
  font-size: 24px;
}
.logo span {
  color: #94a3b8;
  font-size: 13px;
}
nav {
  display: grid;
  gap: 8px;
  margin-top: 32px;
}
.nav-btn, .logout {
  width: 100%;
  text-align: left;
  background: transparent;
  color: #cbd5e1;
  border-radius: 10px;
}
.nav-btn.active, .nav-btn:hover {
  background: var(--red);
  color: white;
}
.logout {
  margin-top: 30px;
  background: #1e293b;
}
.main { padding: 28px; }
.top {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: center;
  margin-bottom: 24px;
}
.top h2 {
  margin: 0 0 6px;
  font-size: 28px;
}
.top p { margin: 0; }
.top a {
  color: var(--red);
  font-weight: 800;
  text-decoration: none;
}
.cards {
  display: grid;
  grid-template-columns: repeat(4, minmax(140px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}
.cards article, .panel, .table-wrap, .editor-form {
  background: white;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px;
}
.cards strong {
  display: block;
  font-size: 32px;
}
.cards span { color: var(--muted); }
.toolbar {
  margin-bottom: 14px;
}
.table-wrap {
  overflow: auto;
  padding: 0;
}
table {
  width: 100%;
  border-collapse: collapse;
}
th, td {
  padding: 14px;
  border-bottom: 1px solid var(--border);
  text-align: left;
  vertical-align: top;
}
th { background: #f1f5f9; }
.grid2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.editor-form button {
  margin-top: 18px;
}
.small-btn {
  padding: 7px 10px;
  margin-right: 6px;
  font-size: 13px;
}
.status-pill {
  display: inline-block;
  padding: 4px 8px;
  border-radius: 999px;
  background: #e2e8f0;
  font-size: 12px;
  font-weight: 800;
}
.status-published { background: #dcfce7; color: #166534; }
.status-draft { background: #fef3c7; color: #92400e; }
.status-hidden { background: #fee2e2; color: #991b1b; }
@media (max-width: 900px) {
  .admin-shell { grid-template-columns: 1fr; }
  .sidebar { position: static; }
  .cards, .grid2 { grid-template-columns: 1fr; }
}


/* v20260710: 本地图片上传 */
.media-uploader {
  border: 1px dashed #cbd5e1;
  border-radius: 12px;
  padding: 16px;
  background: #f8fafc;
}
.media-uploader input[type="file"] { background: white; }
.media-help { margin-top: 8px; color: var(--muted); font-size: 13px; line-height: 1.6; }
.media-preview-wrap { margin-top: 14px; display: flex; align-items: flex-start; gap: 12px; }
.media-preview-wrap img { width: min(360px, 100%); max-height: 220px; object-fit: cover; border-radius: 10px; border: 1px solid var(--border); }
.secondary-btn { background: #475569 !important; margin-top: 0 !important; white-space: nowrap; }
.upload-progress { margin-top: 10px; font-size: 13px; font-weight: 700; color: #166534; }
.url-fallback { margin: 12px 0 18px; color: var(--muted); }
.url-fallback summary { cursor: pointer; font-size: 13px; }
.url-fallback input { margin-top: 10px; }
button:disabled { opacity: .6; cursor: wait; }

/* Editor v2: multi-source cover, auto summary and SEO */
.field-heading { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:18px; }
.field-heading label { margin:0; }
.compact-btn { width:auto; padding:8px 12px; font-size:14px; }
.upload-methods { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.upload-method { min-height:88px; border:1px dashed #b8c5d8; border-radius:10px; padding:14px; background:#fff; display:flex; flex-direction:column; justify-content:center; gap:8px; }
.upload-method input { padding:8px; }
.paste-method { cursor:text; }
.media-uploader:focus-within, .media-uploader.is-paste-active { outline:3px solid rgba(14,165,233,.25); border-color:#0ea5e9; }
.external-url-box { margin-top:14px; }
.external-url-box label { margin-top:0; }
@media (max-width:760px) { .upload-methods { grid-template-columns:1fr; } .field-heading { align-items:flex-start; flex-direction:column; } }


/* v30 AI cover controls */
.ai-cover-box { margin: 18px 0 22px; padding: 16px; border: 1px solid #d8dee9; border-radius: 10px; background: #fbfcfe; }
.ai-cover-box .field-heading { margin-bottom: 10px; }
.ai-auto-label { display: flex; align-items: center; gap: 9px; font-weight: 700; margin: 12px 0 8px; }
.ai-auto-label input { width: 18px; height: 18px; }
